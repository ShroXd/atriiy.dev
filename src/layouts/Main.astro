---
import Breadcrumbs from "@components/Breadcrumbs.astro";

export interface Props {
  pageTitle: string;
  pageDesc?: string;
}

const { pageTitle, pageDesc } = Astro.props;
---

<Breadcrumbs />
<main id="main-content">
  <h1>{pageTitle}</h1>
  <p>{pageDesc}</p>
  <div class="mt-12">
    <slot />
  </div>
</main>

<style>
  #main-content {
    @apply mx-auto w-full max-w-3xl px-4 pb-12;
  }
  #main-content h1 {
    @apply text-2xl text-skin-primary font-semibold mt-6;
  }
  #main-content p {
    @apply mb-6 mt-2 text-base text-skin-body italic;
  }
</style>
